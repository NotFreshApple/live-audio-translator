<Window x:Class="LiveAudioTranslator.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:languages="clr-namespace:LiveAudioTranslator.App.Services.Languages"
        mc:Ignorable="d"
        Title="라이브 오디오 번역기"
        Width="1520"
        Height="220"
        MinWidth="980"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        Loaded="Window_OnLoaded"
        Closing="Window_OnClosing">
    <Border Margin="16,0,16,12"
            Padding="12"
            VerticalAlignment="Stretch"
            CornerRadius="18"
            Background="#B3000000"
            BorderBrush="#33FFFFFF"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="96" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="96" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button x:Name="CaptureToggleButton"
                        Width="28"
                        Height="28"
                        Padding="0"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Click="CaptureToggleButton_OnClick"
                        Content="●"
                        ToolTip="오디오 캡처 켜기 또는 끄기" />

                <ComboBox x:Name="RecognitionLanguageComboBox"
                          Grid.Column="2"
                          Width="96"
                          Height="24"
                          FontSize="11"
                          VerticalAlignment="Center"
                          DisplayMemberPath="DisplayName"
                          SelectionChanged="RecognitionLanguageComboBox_OnSelectionChanged" />

                <ComboBox x:Name="TranslationLanguageComboBox"
                          Grid.Column="4"
                          Width="96"
                          Height="24"
                          FontSize="11"
                          VerticalAlignment="Center"
                          DisplayMemberPath="DisplayName"
                          SelectionChanged="TranslationLanguageComboBox_OnSelectionChanged" />

                <StackPanel Grid.Column="6"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="StatusTextBlock"
                               Margin="0,0,8,0"
                               Text="대기 중"
                               Foreground="White"
                               FontSize="11"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />

                    <TextBlock x:Name="DetailTextBlock"
                               Width="220"
                               Margin="0,0,8,0"
                               Text="캡처를 켜면 기본 출력 장치의 시스템 오디오를 감시합니다."
                               Foreground="#C8C8C8"
                               FontSize="10"
                               VerticalAlignment="Center"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis" />

                    <Border Padding="6,4"
                            Margin="0,0,6,0"
                            CornerRadius="999"
                            Background="#191919"
                            BorderBrush="#2A2A2A"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="CaptureEnabledIndicator"
                                     Width="6"
                                     Height="6"
                                     Margin="0,0,4,0"
                                     VerticalAlignment="Center"
                                     Fill="#6E6E6E" />
                            <TextBlock Text="캡처"
                                       Foreground="#F2F2F2"
                                       FontSize="10"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border Padding="6,4"
                            Margin="0,0,6,0"
                            CornerRadius="999"
                            Background="#191919"
                            BorderBrush="#2A2A2A"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="CaptureHealthIndicator"
                                     Width="6"
                                     Height="6"
                                     Margin="0,0,4,0"
                                     VerticalAlignment="Center"
                                     Fill="#6E6E6E" />
                            <TextBlock Text="인식"
                                       Foreground="#F2F2F2"
                                       FontSize="10"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border Padding="6,4"
                            CornerRadius="999"
                            Background="#191919"
                            BorderBrush="#2A2A2A"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="AudioSignalIndicator"
                                     Width="6"
                                     Height="6"
                                     Margin="0,0,4,0"
                                     VerticalAlignment="Center"
                                     Fill="#6E6E6E" />
                            <TextBlock Text="신호"
                                       Foreground="#F2F2F2"
                                       FontSize="10"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Button x:Name="CloseButton"
                        Grid.Column="8"
                        Width="28"
                        Height="28"
                        Padding="0"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Click="CloseButton_OnClick"
                        Content="✕"
                        ToolTip="프로그램 종료" />
            </Grid>

            <Grid Grid.Row="2">
                <Border Padding="14,12"
                        CornerRadius="14"
                        Background="#14000000"
                        BorderBrush="#26FFFFFF"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border x:Name="OriginalPlaceholderBorder"
                                Padding="10,8"
                                CornerRadius="10"
                                Background="#10000000"
                                BorderBrush="#30FFFFFF"
                                BorderThickness="1">
                            <TextBlock Text="원문 표시 영역"
                                       Foreground="#88FFFFFF"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center" />
                        </Border>

                        <TextBlock x:Name="OriginalTextBlock"
                                   Text="원문 텍스트가 이 줄에 표시됩니다."
                                   Foreground="#F7F7F7"
                                   FontSize="21"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />

                        <Grid Grid.Row="2">
                            <Border x:Name="TranslatedPlaceholderBorder"
                                    Padding="10,8"
                                    CornerRadius="10"
                                    Background="#0D0F1A"
                                    BorderBrush="#305E8CFF"
                                    BorderThickness="1">
                                <TextBlock Text="번역 자막 영역"
                                           Foreground="#88B9D4FF"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center" />
                            </Border>

                            <TextBlock x:Name="TranslatedTextBlock"
                                       Text="번역 텍스트가 이 줄에 표시됩니다."
                                       Foreground="#B9D4FF"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
